+    def _project_ba(self, hidden_states: torch.Tensor) -> tuple[torch.Tensor, None]:
+        """Compute the in_proj_ba projection.
+
+        For Qwen3-Next (gqa_interleaved_layout=True) this delegates to the
+        original MergedColumnParallelLinear, which already produces the
+        per-rank shape downstream code expects.
+
+        For Qwen3.5 (gqa_interleaved_layout=False) this is the Marlin TP=4
+        workaround: project hidden_states through two replicated b/a linears
+        (full output on every rank), slice this rank's TP portion, and
+        concatenate so the returned tensor matches the shape that
+        MergedColumnParallelLinear with output_sizes=[num_v_heads]*2 would
+        have produced (i.e. last dim = 2 * num_v_heads / tp_size).
+        """
+        if self.gqa_interleaved_layout:
+            return self.in_proj_ba(hidden_states)
+        full_b, _ = self.in_proj_b(hidden_states)
+        full_a, _ = self.in_proj_a(hidden_states)
+        chunk = self.num_v_heads // self.tp_size
+        start = self.tp_rank * chunk
+        end = start + chunk
+        b = full_b[..., start:end].contiguous()
+        a = full_a[..., start:end].contiguous()
+        return torch.cat([b, a], dim=-1), None
